{
  "entities": {
    "Contact": {
      "title": "Contact Form Submission",
      "description": "Information from users who want to get in touch.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "message": { "type": "string", "description": "The message sent by the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "Project": {
      "title": "Portfolio Project",
      "description": "A project showcased in the portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "description": { "type": "string", "description": "Project description" },
        "result": { "type": "string", "description": "The outcome of the project" },
        "strategies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "SEO strategies used"
        },
        "order": { "type": "integer", "description": "Display order" }
      },
      "required": ["title", "description", "result", "strategies", "order"]
    }
  },
  "firestore": {
    "contacts/{contactId}": {
      "schema": "Contact",
      "description": "Collection of contact form submissions"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    }
  }
}
